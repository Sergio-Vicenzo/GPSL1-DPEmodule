 % kTot     = 100;                          % epochs
 % dt       = 1;                            % 1 Hz
 % satPosMat= randn(m,3,kTot)*2.7e7;        % fake satellite XYZ [m]
 % trueX    = [0;0;0;0;0;0;0;0];            % stationary at ECEF origin
 % prTrue   = squeeze(vecnorm(satPosMat - trueX(1:3).',2,2)) + trueX(7);
 % prNoise  = 3;                            % 3 m σ
 % prMat    = prTrue + prNoise*randn(m,kTot);
 % Q        = diag([0.01*ones(1,3), 0.001*ones(1,3), 1, 0.01]);
 % R        = prNoise^2*eye(m);
 % x0       = [1e6;1e6;1e6; 0;0;0; 100; 0];
 % P0       = diag([1e6*ones(1,3), 10*ones(1,3), 1e4, 1e2]);
 % [~,~,xHist] = ckf_gnss(prMat, satPosMat, dt, Q, R, x0, P0);
 % figure;plot3(xHist(1,:),xHist(2,:),xHist(3,:)); grid on;
 
